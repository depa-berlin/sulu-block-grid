{% set block_id = content._id|default %}
<div class="block--grid-row-2col {{ content.attr_class|default('') }}" data-cms-block-id="{{ block_id }}" {{ sulu_block_preview(content) }}>
    <div class="{% if content.col1_attr_class|default %} {{ content.col1_attr_class }}{% endif %}">
        {% if content.col1_blocks|default([]) %}
            {% for block in content.col1_blocks %}
                {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                    content: block,
                    view: view.col1_blocks[loop.index0],
                } %}
            {% endfor %}
        {% endif %}
    </div>
    <div class="{% if content.col2_attr_class|default %} {{ content.col2_attr_class }}{% endif %}">
        {% if content.col2_blocks|default([]) %}
            {% for block in content.col2_blocks %}
                {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                    content: block,
                    view: view.col2_blocks[loop.index0],
                } %}
            {% endfor %}
        {% endif %}
    </div>
</div>
