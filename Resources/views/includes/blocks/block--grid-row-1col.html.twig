{% set block_id = content._id|default %}
<div class="block--grid-row-1col {{ content.attr_class|default('') }}" data-cms-block-id="{{ block_id }}" {{ sulu_block_preview(content) }}>
    <div {% if content.col1_attr_class|default %}class="{{ content.col1_attr_class }}"{% endif %}>
        {% if content.col1_blocks|default([]) %}
            {% for block in content.col1_blocks %}
                {% include 'includes/blocks/' ~ block.type ~ '.html.twig' with {
                    content: block,
                    view: view.col1_blocks[loop.index0],
                } %}
            {% endfor %}
        {% endif %}
    </div>
</div>
