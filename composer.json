{
    "name": "depa-berlin/sulu-block-grid",
    "description": "Grid block collection for Sulu CMS (css-grid, grid-row, grid-col, grid-three-col)",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Depa\\SuluBlockGridBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Depa\\SuluBlockGridBundle\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
